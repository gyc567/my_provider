# Private Key (secp256k1)
PROVIDER_PRIVATE_KEY=your_private_key_here

# Public Key (secp256k1)
# your_public_key_here

# Server Configuration
PORT=8080
TZERO_ENDPOINT=https://api-sandbox.t-0.network

# Quote Publishing Interval in milliseconds
# QUOTE_PUBLISHING_INTERVAL=5000
NETWORK_PUBLIC_KEY=0x041b6acf3e830b593aaa992f2f1543dc8063197acfeecefd65135259327ef3166acaca83d62db19eb4fecb3d04e44094378839b8c13a2af26bf78fed56a4af935b

# --- /api/v1/quotes/pay-out (provider product HTTP API) ---

# Comma-separated list of pre-shared API keys. Frontend must send one as
# `Authorization: Bearer <key>`. Empty list = all requests get 401.
# Generate these out-of-band (e.g. `openssl rand -hex 32`).
PROVIDER_API_KEYS=key1,key2,key3

# Whether the 5-second ticker pushes a default pay-out quote.
#   true  (default): ticker pushes default PayOut, frontend can override.
#                    Use during the transition period while frontend adopts
#                    the new /api/v1/quotes/pay-out endpoint.
#   false: ticker only pushes PayIn. PayOut comes exclusively from the
#                    HTTP endpoint. Set this AFTER the frontend is live.
PUBLISH_PAY_OUT_DEFAULT=true